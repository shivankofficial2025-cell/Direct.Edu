# Application
NODE_ENV=development
APP_NAME=DirectEdu
APP_PORT=5000
APP_HOST=localhost
APP_LOG_LEVEL=info

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME=DirectEdu

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/directedu
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DURATION=3600

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRY=7d

# Session
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_EXPIRY=1440

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@directedu.com

# AI Services
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=your-anthropic-key
AI_MODEL_STUDY=gpt-4-turbo
AI_MODEL_TEACHER=gpt-4-turbo
AI_MODEL_ADMIN=gpt-4-turbo

# Authentication
AUTH_GOOGLE_CLIENT_ID=your-google-client-id
AUTH_GOOGLE_CLIENT_SECRET=your-google-secret
AUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
AUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-secret

# AWS/Cloud Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=directedu-bucket

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
FEATURE_AI_ASSISTANT=true
FEATURE_TRANSPORT=true
FEATURE_HOSTEL=true
FEATURE_LIBRARY=true
FEATURE_HEALTH=true

# License
LICENSE_KEY=dev-license-key
